@article{wen_ammonia_2025,
	title = {Ammonia as a renewable energy carrier from synthesis to utilization},
	volume = {1},
	copyright = {2025 Springer Nature Limited},
	issn = {3005-0685},
	url = {https://www.nature.com/articles/s44359-025-00102-9},
	doi = {10.1038/s44359-025-00102-9},
	abstract = {Ammonia has potential to play a key role in large-scale, long-term storage and transport of renewable energy. Renewable energy generation, particularly from solar and wind sources, has increased substantially but faces challenges such as intermittency and decentralization. Energy storage technologies are vital for addressing these issues, with chemical energy storage, especially ammonia, offering long-term (weeks) and large-scale (10–1,000 MW) energy storage. In this Review, we explore the role of ammonia in the energy landscape, focusing on its synthesis and utilization. Ammonia has advantages over hydrogen, such as higher volumetric energy density (12.7 MJ l−1) and simpler storage requirements (readily liquefied at {\textasciitilde}10 bar or −33 °C). It can be synthesized using renewable electricity and later decomposed to release hydrogen or used directly in fuel cells, including direct-ammonia fuel cells, indirect-ammonia fuel cells and ammonia solid-oxide fuel cells. We show that although decentralized ammonia synthesis under mild conditions offers potential for localized, low-carbon production, it remains limited by high energy costs and scalability challenges, underscoring the need for breakthroughs in catalyst efficiency and system design. The successful integration of ammonia into renewable energy systems will require coordinated efforts across technology development, policy support and infrastructure expansion.},
	language = {en},
	number = {11},
	urldate = {2025-11-26},
	journal = {Nature Reviews Clean Technology},
	publisher = {Nature Publishing Group},
	author = {Wen, Zuxin and Huang, Bing and Wang, Yaolin and Wang, Ke and Tu, Xin and Xie, Pengfei and Fu, Xianbiao},
	month = nov,
	year = {2025},
	keywords = {Energy, Energy storage, Green chemistry},
	pages = {755--770},
	file = {Full Text PDF:/Users/maddymurphy/Zotero/storage/JI5KI5IU/Wen et al. - 2025 - Ammonia as a renewable energy carrier from synthesis to utilization.pdf:application/pdf},
}

