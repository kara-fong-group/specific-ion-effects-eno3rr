	file = {IOP Full Text PDF:/Users/maddymurphy/Zotero/storage/WKIUPSRJ/Balucani et al. - 1985 - Self-diffusion and relative diffusion processes in liquids microdynamic and hydrodynamic points of.pdf:application/pdf},
}

