@article{moultos_system-size_2016,
	title = {System-size corrections for self-diffusion coefficients calculated from molecular dynamics simulations: {The} case of {CO2}, \textit{n} -alkanes, and poly(ethylene glycol) dimethyl ethers},
	volume = {145},
	issn = {0021-9606, 1089-7690},
	shorttitle = {System-size corrections for self-diffusion coefficients calculated from molecular dynamics simulations},
